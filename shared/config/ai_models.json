{
  "version": "1.0",
  "provider": "openrouter",
  "base_url": "https://openrouter.ai/api/v1",
  "primary": {
    "model": "google/gemini-2.5-flash",
    "max_tokens": 200,
    "temperature": 0.7,
    "timeout_seconds": 15,
    "cost_per_1k_input": 0.00015,
    "cost_per_1k_output": 0.0006
  },
  "fallback": {
    "model": "deepseek/deepseek-chat-v3-0324",
    "max_tokens": 200,
    "temperature": 0.7,
    "timeout_seconds": 15,
    "cost_per_1k_input": 0.00014,
    "cost_per_1k_output": 0.00028
  },
  "summary": {
    "model": "openai/gpt-4o-mini",
    "max_tokens": 300,
    "temperature": 0.3,
    "timeout_seconds": 15,
    "note": "Саммари при handoff — 3 строки: кто, налоги, боль"
  },
  "whisper": {
    "provider": "openai",
    "model": "whisper-1",
    "timeout_seconds": 30,
    "max_audio_duration_seconds": 120
  },
  "semaphore_limit": 3,
  "fallback_system_suffix": "Strictly follow: ONE question per message, no lists, max 3 sentences."
}
